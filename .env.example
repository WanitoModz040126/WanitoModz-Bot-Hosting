# Server
PORT=3000
NODE_ENV=production

# Required: long random strings. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string
TOKEN_ENCRYPTION_KEY=change_this_to_a_32_byte_hex_or_any_long_random_string

# Optional: Cloudflare Turnstile (bot/abuse check on login & signup).
# Leave blank to disable - the app works fully without it.
# Get keys at https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Plan limits (free plan defaults)
MAX_BOTS_PER_USER=3
MAX_STORAGE_BYTES=2684354560
