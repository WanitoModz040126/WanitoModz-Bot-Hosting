<%- include('partials/head', { pageTitle: bot.name + ' — WanitoModz Hosting' }) %>
<body>
  <div class="app-shell">
    <%- include('partials/nav', { user: user, active: 'dashboard' }) %>

    <main class="main-content">
      <div class="page-pad" data-bot-id="<%= bot.id %>">
        <div class="page-head">
          <div>
            <h1><%= bot.name %></h1>
            <p class="page-sub"><%= bot.library %> · uploaded as <code><%= bot.entryFile %></code></p>
          </div>
          <a href="/dashboard" class="btn btn-ghost btn-sm">← Back to dashboard</a>
        </div>

        <div class="bot-detail-head">
          <span class="status-pill <%= bot.status %>" id="statusPill"><%= bot.status %></span>
          <button class="btn btn-secondary" id="startBtn" style="<%= bot.status === 'running' ? 'display:none' : '' %>">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M8 5l11 7-11 7V5z" fill="currentColor"/></svg> Start
          </button>
          <button class="btn btn-secondary" id="stopBtn" style="<%= bot.status !== 'running' ? 'display:none' : '' %>">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><rect x="6" y="6" width="12" height="12" rx="2" fill="currentColor"/></svg> Stop
          </button>
          <button class="btn btn-danger" id="deleteBotBtn">Delete bot</button>
        </div>

        <div class="section-card">
          <div class="section-head"><h2>Live logs</h2><button class="link-btn" id="clearViewBtn" title="Clear view"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M4 7h16M9 7V4h6v3M6 7l1 13h10l1-13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></button></div>
          <div class="terminal">
            <div class="terminal-head">
              <div class="dots"><span></span><span></span><span></span></div>
              <span class="terminal-title"><%= bot.entryFile %> — run.log</span>
            </div>
            <div class="terminal-body" id="logBody">
              <% if (!recentLogs.length) { %>
                <div class="terminal-empty">No logs yet. Start the bot to see live output here.</div>
              <% } else { %>
                <% recentLogs.forEach(function(line){ %><div class="log-line<%= line.startsWith('[err]') ? ' is-err' : (line.startsWith('[system]') ? ' is-system' : '') %>"><%= line %></div><% }) %>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="confirmModal">
    <div class="modal">
      <h3>Delete this bot?</h3>
      <p style="color:var(--text-muted);font-size:13.5px;">This stops the process and permanently removes its uploaded files. This can't be undone.</p>
      <div class="modal-actions">
        <button class="btn btn-ghost" id="confirmCancel">Cancel</button>
        <button class="btn btn-danger" id="confirmDelete">Delete bot</button>
      </div>
    </div>
  </div>

  <div id="toastStack"></div>
  <script src="/js/toast.js"></script>
  <script src="/js/app-shell.js"></script>
  <script src="/js/bot-detail.js"></script>
</body>
</html>
